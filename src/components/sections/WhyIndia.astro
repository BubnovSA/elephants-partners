---
import type { Translations } from '@/i18n/en';

interface Props { t: Translations }
const { t } = Astro.props;

const icons = [
  `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`,
  `<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/>`,
  `<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 01.01 2.22 2 2 0 012 .04h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>`,
  `<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>`,
  `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>`,
];
---

<section class="section why-india" id="why-india" aria-labelledby="why-india-heading">
  <div class="container">
    <div class="why-india-inner">
      <div class="why-india-text">
        <span class="eyebrow">{t.whyIndia.eyebrow}</span>
        <span class="rule"></span>
        <h2 id="why-india-heading" class="heading-2">
          {t.whyIndia.heading[0]}<br>
          <span class="accent">{t.whyIndia.heading[1]}</span>
        </h2>
        <p class="body-lg" style="color: var(--color-text-muted)">
          {t.whyIndia.description}
        </p>
        <p class="why-india-tagline">
          {t.whyIndia.tagline}
        </p>
      </div>

      <ul class="why-india-list" role="list">
        {t.whyIndia.reasons.map(({ title, desc }, i) => (
          <li class="why-india-item">
            <div class="why-india-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={icons[i]} />
              </svg>
            </div>
            <div>
              <strong class="why-india-item-title">{title}</strong>
              <p class="why-india-item-desc">{desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .why-india {
    background: linear-gradient(165deg, #F0ECE2 0%, #F8F5EE 60%, #ECE8DE 100%);
    background-image:
      radial-gradient(ellipse 65% 55% at 100% 10%, rgba(45,138,106,0.20) 0%, transparent 50%),
      radial-gradient(ellipse 45% 40% at  0% 90%, rgba(160,110,30,0.10) 0%, transparent 50%);
  }
  :global([data-theme="dark"]) .why-india-icon {
    background: linear-gradient(145deg, rgba(61,170,133,0.18) 0%, rgba(42,122,94,0.12) 100%);
    border-color: rgba(61,170,133,0.2);
  }
  :global([data-theme="dark"]) .why-india {
    background: var(--color-surface-alt);
    background-image:
      radial-gradient(ellipse 65% 55% at 100% 10%, rgba(61,170,133,0.1) 0%, transparent 50%),
      radial-gradient(ellipse 45% 40% at  0% 90%, rgba(42,122,94,0.06) 0%, transparent 50%);
  }

  .why-india-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .why-india-inner {
      grid-template-columns: 5fr 6fr;
      gap: var(--space-16);
    }
  }

  .why-india-text .rule { margin-bottom: var(--space-4); }
  .why-india-text h2 { margin-bottom: var(--space-5); }

  .why-india-tagline {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
  }

  .why-india-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .why-india-item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .why-india-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: linear-gradient(145deg, rgba(45,138,106,0.18) 0%, rgba(15,77,63,0.08) 100%);
    border: 1px solid rgba(45,138,106,0.15);
    border-radius: var(--radius-md);
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .why-india-item-title {
    display: block;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .why-india-item-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: var(--line-height-normal);
  }
</style>
