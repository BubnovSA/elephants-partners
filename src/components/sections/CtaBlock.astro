---
import type { Translations } from '@/i18n/en';

interface Props { t: Translations }
const { t } = Astro.props;

const TELEGRAM_URL = 'https://t.me/elephantpartners';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="cta-wrap section" aria-labelledby="cta-heading">
  <div class="container">
    <div class="cta-inner">
      <div class="cta-blob cta-blob--1" aria-hidden="true"></div>
      <div class="cta-blob cta-blob--2" aria-hidden="true"></div>
      <div class="cta-dots" aria-hidden="true"></div>

      <div class="cta-content" data-reveal>
        <span class="eyebrow eyebrow--inv">{t.cta.eyebrow}</span>
        <h2 id="cta-heading" class="heading-2 cta-heading">
          {t.cta.heading[0]}<br>
          <span class="cta-accent">{t.cta.heading[1]}</span>
        </h2>
        <p class="cta-desc">
          {t.cta.description}
        </p>
        <div class="cta-actions">
          <a href={TELEGRAM_URL} class="cta-btn-telegram" target="_blank" rel="noopener noreferrer">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
            {t.cta.btnTelegram}
          </a>
          <a href={`mailto:${t.cta.btnEmail}`} class="cta-btn-email">
            {t.cta.btnEmail}
          </a>
        </div>
      </div>

      <div class="cta-side">
        <figure class="cta-media">
          <img
            src={`${basePath}/assets/success.webp`}
            alt=""
            class="cta-media-img"
            loading="lazy"
            decoding="async"
            width="640"
            height="480"
          />
        </figure>

        <div class="cta-visual" aria-hidden="true">
          <div class="cta-card-stack">
            {t.cta.miniCards.map(({ label, value, color }, i) => (
              <div class={`cta-mini-card cta-mini-card--${i + 1}`}>
                <div class={`cmc-dot${color !== 'green' ? ` cmc-dot--${color}` : ''}`}></div>
                <span>{label}</span>
                <strong>{value}</strong>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-wrap { background: var(--color-bg-warm); }

  .cta-inner {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-2xl);
    background: linear-gradient(130deg, #0A3830 0%, #0F4D3F 40%, #1A6B52 100%);
    box-shadow: 0 24px 72px rgba(15,77,63,0.35), inset 0 1px 0 rgba(255,255,255,0.08);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    padding: var(--space-10) var(--space-6);
  }

  @media (min-width: 1024px) {
    .cta-inner {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: var(--space-10);
      padding: var(--space-16) var(--space-12);
    }
  }

  .cta-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(64px);
  }
  .cta-blob--1 {
    width: 400px; height: 400px;
    background: rgba(45,138,106,0.25);
    top: -100px; right: -50px;
  }
  .cta-blob--2 {
    width: 250px; height: 250px;
    background: rgba(61,170,133,0.15);
    bottom: -60px; left: 30%;
  }

  .cta-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .cta-content { position: relative; z-index: 1; }
  .cta-content .eyebrow { margin-bottom: var(--space-4); }

  .cta-heading {
    color: #fff;
    margin-bottom: var(--space-5);
  }

  .cta-accent { color: var(--color-accent-light); }

  .cta-desc {
    color: rgba(255,255,255,0.65);
    font-size: var(--font-size-base);
    line-height: 1.75;
    max-width: 440px;
    margin-bottom: var(--space-8);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }

  .cta-btn-telegram {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.875rem 1.75rem;
    background: rgba(255,255,255,0.95);
    color: var(--color-primary-dark);
    border-radius: var(--radius-lg);
    font-size: var(--font-size-sm);
    font-weight: 700;
    letter-spacing: 0.01em;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    transition: all var(--transition-fast);
  }
  .cta-btn-telegram:hover {
    background: #fff;
    box-shadow: 0 6px 24px rgba(0,0,0,0.25);
    transform: translateY(-1px);
  }

  .cta-btn-email {
    font-size: var(--font-size-sm);
    color: rgba(255,255,255,0.6);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }
  .cta-btn-email:hover { color: #fff; }

  /* Right column: photo + mini cards */
  .cta-side {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .cta-media {
    margin: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.15);
    box-shadow: 0 16px 48px rgba(0,0,0,0.28);
    line-height: 0;
  }

  .cta-media-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  .cta-visual { display: block; }

  .cta-card-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .cta-card-stack {
      max-width: 280px;
      margin: 0;
    }
  }

  .cta-mini-card {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    backdrop-filter: blur(8px);
    animation: slide-in 0.6s ease backwards;
  }
  .cta-mini-card--1 { animation-delay: 0.1s; }
  .cta-mini-card--2 { animation-delay: 0.25s; }
  .cta-mini-card--3 { animation-delay: 0.4s; }

  @keyframes slide-in {
    from { opacity: 0; transform: translateX(20px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .cta-mini-card span {
    flex: 1;
    font-size: var(--font-size-xs);
    color: rgba(255,255,255,0.55);
    font-weight: 500;
  }
  .cta-mini-card strong {
    font-size: var(--font-size-xs);
    color: #fff;
    font-weight: 700;
    white-space: nowrap;
  }

  .cmc-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-success);
    box-shadow: 0 0 0 3px rgba(22,163,74,0.2);
    flex-shrink: 0;
  }
  .cmc-dot--blue { background: #60a5fa; box-shadow: 0 0 0 3px rgba(96,165,250,0.2); }
  .cmc-dot--orange { background: #f59e0b; box-shadow: 0 0 0 3px rgba(245,158,11,0.2); }
</style>
