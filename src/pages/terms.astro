g---
import BaseLayout from '@/layouts/BaseLayout.astro';
const updated = '2026-05-18';
---

<BaseLayout
  title="Terms of Service — Elephants Partners"
  description="Terms of service for elephants.partners website."
  noindex={false}
>
  <section class="section legal-page">
    <div class="container legal-container">
      <h1 class="heading-2">Terms of Service</h1>
      <p class="legal-updated">Last updated: {updated}</p>

      <div class="legal-content">
        <p>By accessing elephants.partners, you agree to these terms. The website is provided for informational purposes about Elephants Partners' payment infrastructure services.</p>

        <h2>Use of website</h2>
        <p>You may use this website for lawful purposes only. You may not use it in any way that violates applicable local, national, or international laws or regulations.</p>

        <h2>Intellectual property</h2>
        <p>All content on this website — including text, graphics, logos, and images — is the property of Elephants Partners and is protected by applicable intellectual property laws.</p>

        <h2>Disclaimer</h2>
        <p>This website provides general information about our services. It does not constitute financial advice or a legally binding offer. Service terms are governed by individual partnership agreements.</p>

        <h2>Limitation of liability</h2>
        <p>Elephants Partners is not liable for any indirect, incidental, or consequential damages arising from your use of this website.</p>

        <h2>Changes</h2>
        <p>We may update these terms from time to time. Continued use of the website after changes constitutes acceptance of the updated terms.</p>

        <h2>Contact</h2>
        <p>Questions about these terms: <a href="mailto:partnerships@elephants.partners">partnerships@elephants.partners</a></p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-page { background: var(--color-bg); }
  .legal-container { max-width: 720px; }
  .legal-page h1 { margin-bottom: var(--space-2); }
  .legal-updated { font-size: var(--font-size-sm); color: var(--color-text-muted); margin-bottom: var(--space-10); }
  .legal-content { display: flex; flex-direction: column; gap: var(--space-6); }
  .legal-content h2 { font-size: var(--font-size-lg); font-weight: var(--font-weight-semibold); margin-top: var(--space-4); }
  .legal-content p { font-size: var(--font-size-base); color: var(--color-text-muted); line-height: var(--line-height-loose); }
  .legal-content a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
</style>
