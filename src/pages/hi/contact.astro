---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { hi } from '@/i18n/hi';
const t = hi;
const c = t.contact;
const TELEGRAM_URL = 'https://t.me/elephantpartners';
---

<BaseLayout
  title="Elephants Partners से संपर्क करें — UPI पेमेंट इन्फ्रास्ट्रक्चर"
  description="Elephants Partners से संपर्क करें। भारत में आपके व्यवसाय के लिए UPI पेमेंट प्रोसेसिंग पर चर्चा करें।"
  lang="hi"
  canonical="https://elephants.partners/hi/contact"
  t={t}
>
  <section class="section contact-hero">
    <div class="container">
      <span class="eyebrow">{c.eyebrow}</span>
      <span class="rule"></span>
      <h1 class="heading-1">{c.h1[0]}<br><span class="accent">{c.h1[1]}</span></h1>
      <p class="contact-intro body-lg">{c.intro}</p>
    </div>
  </section>

  <section class="section" style="background: var(--color-surface-alt)">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-methods">
          <h2 class="heading-3">{c.directH2}</h2>

          <div class="contact-card card">
            <div class="contact-card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </div>
            <div>
              <h3>{c.methods[0].h3}</h3>
              <p>{c.methods[0].p}</p>
              <a href={TELEGRAM_URL} class="btn btn--primary" target="_blank" rel="noopener noreferrer">{c.methods[0].btnLabel}</a>
            </div>
          </div>

          <div class="contact-card card">
            <div class="contact-card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <h3>{c.methods[1].h3}</h3>
              <p>{c.methods[1].p}</p>
              <a href="mailto:partnerships@elephants.partners" class="contact-email">partnerships@elephants.partners</a>
            </div>
          </div>

          <div class="contact-card card">
            <div class="contact-card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <h3>{c.methods[2].h3}</h3>
              <address style="font-style:normal">
                {c.locations.map(({ label, value }) => (
                  <p><strong>{label}:</strong> {value}</p>
                ))}
              </address>
            </div>
          </div>
        </div>

        <div class="contact-faq">
          <h2 class="heading-3">{c.faqH2}</h2>
          <dl class="faq-list">
            {c.faq.map(({ q, a }) => (
              <div class="faq-item">
                <dt class="faq-q">{q}</dt>
                <dd class="faq-a">{a}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero { background: var(--color-bg); padding-bottom: var(--space-8); }
  .contact-hero .rule { margin-bottom: var(--space-5); }
  .contact-hero h1 { margin-bottom: var(--space-5); }
  .contact-intro { color: var(--color-text-muted); max-width: 480px; }
  .contact-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-10); align-items: start; }
  @media (min-width: 1024px) { .contact-grid { grid-template-columns: 1fr 1fr; gap: var(--space-12); } }
  .contact-methods { display: flex; flex-direction: column; gap: var(--space-5); }
  .contact-methods h2 { margin-bottom: var(--space-2); }
  .contact-card { display: flex; gap: var(--space-4); align-items: flex-start; }
  .contact-card-icon { display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; background: var(--color-accent-pale); border-radius: var(--radius-md); color: var(--color-accent); flex-shrink: 0; }
  .contact-card h3 { font-size: var(--font-size-base); font-weight: 600; margin-bottom: var(--space-2); }
  .contact-card p, .contact-card address { font-size: var(--font-size-sm); color: var(--color-text-muted); margin-bottom: var(--space-3); line-height: var(--line-height-normal); }
  .contact-card address p + p { margin-top: var(--space-1); }
  .contact-email { font-size: var(--font-size-sm); font-weight: 500; color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
  .contact-faq h2 { margin-bottom: var(--space-6); }
  .faq-list { display: flex; flex-direction: column; gap: var(--space-1); }
  .faq-item { padding: var(--space-5); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); }
  .faq-q { font-size: var(--font-size-base); font-weight: 600; color: var(--color-text); margin-bottom: var(--space-2); }
  .faq-a { font-size: var(--font-size-sm); color: var(--color-text-muted); line-height: var(--line-height-loose); }
</style>
